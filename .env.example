# Copy to .env and fill in your keys

# Neo4j (matches docker-compose.yml defaults)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=graphiti_dev

# Anthropic — Graphiti uses this for LLM extraction
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — Graphiti requires this for embeddings (OpenAIEmbedder)
OPENAI_API_KEY=sk-...
