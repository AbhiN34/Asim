# Asim MVP — environment template.
# Copy this file to `.env` (in this same directory) and fill in real values.
# `.env` is gitignored; `.env.local` is committed as a placeholder.

# Neo4j — local instance (Neo4j Desktop is fine).
# If `neo4j://` fails to connect, swap to `bolt://`.
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# OpenAI — used by Graphiti for entity extraction/embeddings AND by /query for RAG.
OPENAI_API_KEY=sk-your-openai-key
